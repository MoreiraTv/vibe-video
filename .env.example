# Local mode is the default. Set to "elevenlabs" if the machine is too weak
# for faster-whisper and you want to use ElevenLabs Scribe instead.
VIBE_VIDEO_TRANSCRIBE_PROVIDER=local

# Required only when VIBE_VIDEO_TRANSCRIBE_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=

# Optional override for ElevenLabs speech-to-text model.
# Current official models include scribe_v2 and scribe_v1.
ELEVENLABS_SPEECH_TO_TEXT_MODEL=scribe_v2
